{
  "name": "gestion-tournoi-tarot",
  "version": "1.0.0",
  "description": "Application de gestion de tournoi de Tarot",
  "type": "module",
  "main": "main.cjs",
  "scripts": {
    "start": "electron .",
    "test": "node --test",
    "pack": "electron-builder --dir",
    "dist": "electron-builder",
    "build:mac": "electron-builder --mac",
    "build:win": "electron-builder --win",
    "build:all": "electron-builder --mac --win"
  },
  "author": "Gino Mollo",
  "license": "ISC",
  "devDependencies": {
    "electron": "^40.1.0",
    "electron-builder": "^26.7.0",
    "eslint": "^8.57.1",
    "eslint-config-standard": "^17.1.0",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-node": "^11.1.0",
    "eslint-plugin-promise": "^7.2.1",
    "jsdom": "^28.1.0"
  },
  "build": {
    "appId": "com.ginomollo.gestiontournoitarot",
    "files": [
      "!**/.venv"
    ],
    "extraResources": [
      {
        "from": "build/defaults",
        "to": "defaults"
      }
    ],
    "mac": {
      "category": "public.app-category.card-games",
      "target": [
        "dmg",
        "zip"
      ],
      "identity": null,
      "icon": "build/icon.icns"
    },
    "win": {
      "target": "nsis",
      "icon": "build/icon.ico"
    },
    "linux": {
      "target": "AppImage"
    }
  }
}
